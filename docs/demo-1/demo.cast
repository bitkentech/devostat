[25.1, "o", "\u001b[1;31m\u2501\u2501\u2501 Task 1 [HIGH] \u2014 De-risk / Harden cycle \u2501\u2501\u2501\u001b[0m\r\n"]
[25.4, "o", "  pom.xml + plugin config + Next.js scaffold + static export wiring\r\n"]
[26.1, "o", "\r\n\u001b[1;33mStep A: De-risking\u001b[0m\r\n"]
[26.6, "o", "  \u001b[2mGoal: Prove Maven + Next.js static export works end-to-end\u001b[0m\r\n\r\n"]
[27.1, "o", "\u001b[1;34m$\u001b[0m npx create-next-app@latest . --ts --tailwind\r\n"]
[27.6, "o", "  \u001b[2mCreating Next.js project in src/main/frontend/...\u001b[0m\r\n"]
[28.3, "o", "  Adding frontend-maven-plugin to pom.xml:\r\n"]
