[3.3, "o", "\r\n\u001b[1;34m>\u001b[0m "]
[3.8, "o", "How about using src/main/frontend for NextJS frontend and this plugin"]
[4.1, "o", " for the build: https://github.com/eirslett/frontend-maven-plugin"]
[4.8, "o", "\r\n"]
[5.6, "o", "\r\n\u001b[2m  Fetching frontend-maven-plugin docs... latest version: 2.0.0\u001b[0m\r\n"]
