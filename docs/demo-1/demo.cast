[29.2, "o", "  \u001b[2m  \u2022 npm run build (Next.js static export)\u001b[0m\r\n"]
[29.5, "o", "  \u001b[2m  \u2022 maven-resources-plugin copies out/ \u2192 target/classes/static/\u001b[0m\r\n"]
[30.3, "o", "\r\n\u001b[1;34m$\u001b[0m mvn package -DskipTests\r\n"]
[31.3, "o", "  \u001b[2m[INFO] Installing Node v20.19.0\u001b[0m\r\n"]
