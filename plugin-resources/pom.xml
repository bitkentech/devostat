<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.github.pramodbiligiri</groupId>
    <artifactId>devostat</artifactId>
    <version>0.1.0</version>
  </parent>

  <artifactId>plugin-resources</artifactId>
  <packaging>pom</packaging>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.3.1</version>
        <executions>

          <!-- Copy and filter SKILL.md into build/skills/{plugin.skillName}/ -->
          <execution>
            <id>copy-skill</id>
            <phase>process-resources</phase>
            <goals>
              <goal>copy-resources</goal>
            </goals>
            <configuration>
              <outputDirectory>${build.outputDir}/skills/${plugin.skillName}</outputDirectory>
              <resources>
                <resource>
                  <directory>${project.basedir}/src/main/resources/skills/devostat</directory>
                  <filtering>true</filtering>
                  <includes>
                    <include>SKILL.md</include>
                  </includes>
                </resource>
              </resources>
            </configuration>
          </execution>

        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <profile>
      <id>claude</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-resources-plugin</artifactId>
            <version>3.3.1</version>
            <executions>

              <!-- Copy and filter plugin metadata into build/.claude-plugin/ -->
              <execution>
                <id>copy-plugin-meta</id>
                <phase>process-resources</phase>
                <goals>
                  <goal>copy-resources</goal>
                </goals>
                <configuration>
                  <outputDirectory>${build.outputDir}/.claude-plugin</outputDirectory>
                  <resources>
                    <resource>
                      <directory>${project.basedir}/src/main/resources/claude-plugin</directory>
                      <filtering>true</filtering>
                      <excludes>
                        <exclude>marketplace.json</exclude>
                      </excludes>
                    </resource>
                  </resources>
                </configuration>
              </execution>

              <!-- Copy Claude hooks into build/hooks/ -->
              <execution>
                <id>copy-hooks</id>
                <phase>process-resources</phase>
                <goals>
                  <goal>copy-resources</goal>
                </goals>
                <configuration>
                  <outputDirectory>${build.outputDir}/hooks</outputDirectory>
                  <resources>
                    <resource>
                      <directory>${project.basedir}/src/main/resources/hooks</directory>
                      <filtering>false</filtering>
                    </resource>
                  </resources>
                </configuration>
              </execution>

              <!-- Copy and filter marketplace.json into build/.claude-plugin/ -->
              <execution>
                <id>copy-marketplace</id>
                <phase>process-resources</phase>
                <goals>
                  <goal>copy-resources</goal>
                </goals>
                <configuration>
                  <outputDirectory>${build.outputDir}/.claude-plugin</outputDirectory>
                  <resources>
                    <resource>
                      <directory>${project.basedir}/src/main/resources/claude-plugin</directory>
                      <filtering>true</filtering>
                      <includes>
                        <include>marketplace.json</include>
                      </includes>
                    </resource>
                  </resources>
                </configuration>
              </execution>

            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <profile>
      <id>gemini</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-resources-plugin</artifactId>
            <version>3.3.1</version>
            <executions>

              <!-- Copy and filter gemini-extension.json into build-gemini/ -->
              <execution>
                <id>copy-gemini-manifest</id>
                <phase>process-resources</phase>
                <goals>
                  <goal>copy-resources</goal>
                </goals>
                <configuration>
                  <outputDirectory>${build.outputDir}</outputDirectory>
                  <resources>
                    <resource>
                      <directory>${project.basedir}/src/main/resources/gemini-extension</directory>
                      <filtering>true</filtering>
                      <includes>
                        <include>gemini-extension.json</include>
                      </includes>
                    </resource>
                  </resources>
                </configuration>
              </execution>

              <!-- Copy commands/ into build-gemini/commands/ -->
              <execution>
                <id>copy-commands</id>
                <phase>process-resources</phase>
                <goals>
                  <goal>copy-resources</goal>
                </goals>
                <configuration>
                  <outputDirectory>${build.outputDir}/commands</outputDirectory>
                  <resources>
                    <resource>
                      <directory>${project.basedir}/src/main/resources/gemini-extension/commands</directory>
                      <filtering>false</filtering>
                    </resource>
                  </resources>
                </configuration>
              </execution>

              <!-- Copy Gemini hooks into build-gemini/hooks/ -->
              <execution>
                <id>copy-gemini-hooks</id>
                <phase>process-resources</phase>
                <goals>
                  <goal>copy-resources</goal>
                </goals>
                <configuration>
                  <outputDirectory>${build.outputDir}/hooks</outputDirectory>
                  <resources>
                    <resource>
                      <directory>${project.basedir}/src/main/resources/gemini-extension/hooks</directory>
                      <filtering>false</filtering>
                    </resource>
                  </resources>
                </configuration>
              </execution>

            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>

</project>
